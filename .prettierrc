{
	"useTabs": true,
	"tabWidth": 4,
	"semi": false,
	"bracketSpacing": false,
	"arrowParens": "avoid",
	"trailingComma": "none",
	"bracketSameLine": true,
	"singleQuote": true,
	"printWidth": 88,
	"overrides": [
		{
			"files": "*.html",
			"options": {
				"parser": "angular",
				"printWidth": 88
			}
		},
		{
			"files": "*.component.html",
			"options": {
				"singleAttributePerLine": true
			}
		}
	]
}